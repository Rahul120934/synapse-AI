// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: sessions
// Document ID: sessionId
// Fields:
//   - title: string (required)
//   - lecturer: string
//   - topic: string
//   - duration: number
//   - wordCount: number
//   - confidence: number
//   - summary: string
//   - takeaways: list (objects with title, description, icon)
//   - transcript: string
//   - createdAt: timestamp (required)
//   - uid: string (required)
//
// Collection: quizzes
// Document ID: quizId
// Fields:
//   - sessionId: string (required)
//   - score: number
//   - totalQuestions: number
//   - questions: list (objects with question, options, correctAnswer, explanation)
//   - createdAt: timestamp (required)
//   - uid: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "rahulnarvekar284@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidSession(data) {
      return hasRequiredFields(['title', 'uid', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.uid == request.auth.uid &&
             (data.lecturer == null || (data.lecturer is string && data.lecturer.size() < 100)) &&
             (data.topic == null || (data.topic is string && data.topic.size() < 200)) &&
             (data.duration == null || data.duration is number) &&
             (data.wordCount == null || data.wordCount is number) &&
             (data.confidence == null || data.confidence is number) &&
             (data.summary == null || (data.summary is string && data.summary.size() < 5000)) &&
             (data.transcript == null || (data.transcript is string && data.transcript.size() < 50000));
    }

    function isValidQuiz(data) {
      return hasRequiredFields(['sessionId', 'uid', 'createdAt']) &&
             data.sessionId is string &&
             data.uid == request.auth.uid &&
             (data.score == null || data.score is number) &&
             (data.totalQuestions == null || data.totalQuestions is number) &&
             (data.questions == null || data.questions is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sessions/{sessionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSession(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidQuiz(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
    }
  }
}
